---
export interface Props {
  title: string;
  description: string;
  pubDate?: Date;
  modDate?: Date;
  isFAQ?: boolean;
  faqItems?: { question: string; answer: string }[];
}
const { title, description, pubDate, modDate, isFAQ = false, faqItems = [] } = Astro.props;
const siteUrl = 'https://zeroclickjournal.com';
const canonicalURL = new URL(Astro.url.pathname, siteUrl);
const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": title,
  "description": description,
  "url": canonicalURL.toString(),
  "publisher": { "@type": "Organization", "name": "Zero Click Journal", "url": siteUrl },
  ...(pubDate && { "datePublished": pubDate.toISOString() }),
  ...(modDate && { "dateModified": modDate.toISOString() }),
};
const faqSchema = isFAQ && faqItems.length > 0 ? {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqItems.map(item => ({
    "@type": "Question",
    "name": item.question,
    "acceptedAnswer": { "@type": "Answer", "text": item.answer }
  }))
} : null;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />
  <title>{title} — Zero Click Journal</title>
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:type" content="article" />
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  {faqSchema && <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />}
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <style>
    :root {
      --bg:#08080e;--bg2:#111118;--bg3:#1a1a26;
      --border:#1e1e2e;--border2:#2a2a3e;
      --text:#f0f0f8;--text2:#9898b8;--text3:#4a4a68;
      --accent:#6c63ff;--accent2:#a78bfa;
      --green:#34d399;--orange:#fb923c;--red:#f87171;
      --font-display:'Syne',sans-serif;
      --font-body:'Inter',sans-serif;
      --font-mono:'JetBrains Mono',monospace;
    }
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    html{font-family:var(--font-body);background:var(--bg);color:var(--text);font-size:16px;line-height:1.7;-webkit-font-smoothing:antialiased}
    a{color:inherit;text-decoration:none}
    .wrap{max-width:1200px;margin:0 auto;padding:0 32px}
    @media(max-width:600px){.wrap{padding:0 16px}}

    /* ── HEADER ── */
    .site-header{position:sticky;top:0;z-index:100;background:rgba(8,8,14,0.9);backdrop-filter:blur(16px);border-bottom:1px solid var(--border)}
    .header-inner{max-width:1200px;margin:0 auto;padding:0 32px;display:flex;align-items:center;justify-content:space-between;height:64px}
    .logo{display:flex;align-items:center;gap:10px;font-family:var(--font-display);font-size:17px;font-weight:800;letter-spacing:-.03em}
    .logo-icon{width:34px;height:34px;background:linear-gradient(135deg,var(--accent),var(--accent2));border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:17px;font-weight:900;color:#fff;font-family:var(--font-mono);flex-shrink:0}
    .logo-dot{color:var(--accent2)}
    nav{display:flex;align-items:center;gap:2px}
    nav a{font-size:13px;font-weight:500;color:var(--text2);padding:6px 14px;border-radius:6px;transition:color .15s,background .15s}
    nav a:hover{color:var(--text);background:var(--bg3)}
    .nav-cta{background:var(--accent)!important;color:#fff!important;font-weight:600!important}
    .nav-cta:hover{opacity:.9}

    /* ── TAGS ── */
    .tag{display:inline-flex;align-items:center;font-family:var(--font-mono);font-size:10px;font-weight:500;padding:3px 8px;border-radius:4px;letter-spacing:.05em;text-transform:uppercase}
    .tag-seo{background:rgba(52,211,153,.15);color:var(--green)}
    .tag-ai{background:rgba(108,99,255,.18);color:var(--accent2)}
    .tag-llm{background:rgba(251,146,60,.15);color:var(--orange)}

    /* ══════════════════════════════
       HERO BANNER
    ══════════════════════════════ */
    .hero-banner{width:100%;margin-bottom:0}
    .hero-link{display:block}
    .hero-img-wrap{position:relative;height:520px;overflow:hidden}
    @media(max-width:768px){.hero-img-wrap{height:380px}}
    .hero-img-placeholder{position:absolute;inset:0;background:var(--bg2)}
    .hero-pattern{
      position:absolute;inset:0;
      background:
        radial-gradient(ellipse 80% 60% at 60% 40%, rgba(108,99,255,.35) 0%, transparent 65%),
        radial-gradient(ellipse 50% 80% at 20% 80%, rgba(167,139,250,.2) 0%, transparent 60%),
        linear-gradient(135deg,#0d0d1a 0%,#111130 50%,#0a0a18 100%);
    }
    .hero-gradient{position:absolute;inset:0;background:linear-gradient(to top,rgba(8,8,14,1) 0%,rgba(8,8,14,.6) 40%,transparent 70%)}
    .hero-overlay{position:absolute;bottom:0;left:0;right:0;padding:48px 0}
    .hero-title{font-family:var(--font-display);font-size:clamp(28px,5vw,52px);font-weight:800;line-height:1.1;letter-spacing:-.04em;margin:12px 0 14px;max-width:780px}
    .hero-desc{font-size:16px;color:var(--text2);max-width:600px;margin-bottom:16px;line-height:1.6}
    .hero-date{font-family:var(--font-mono);font-size:11px;color:var(--text3);text-transform:uppercase;letter-spacing:.08em}

    /* ══════════════════════════════
       DUO GRID
    ══════════════════════════════ */
    .duo-grid{display:grid;grid-template-columns:1fr 1fr;gap:2px;margin-top:2px}
    @media(max-width:768px){.duo-grid{grid-template-columns:1fr}}
    .duo-card{display:flex;flex-direction:column;background:var(--bg2);overflow:hidden;transition:opacity .2s}
    .duo-card:hover{opacity:.9}
    .duo-img{position:relative;height:260px;overflow:hidden}
    .duo-pattern{position:absolute;inset:0;background:radial-gradient(ellipse 80% 80% at 50% 50%,hsl(var(--hue),60%,25%) 0%,hsl(var(--hue),40%,10%) 100%)}
    .duo-img-overlay{position:absolute;inset:0;background:linear-gradient(to top,var(--bg2) 0%,transparent 60%)}
    .duo-body{padding:24px;flex:1;display:flex;flex-direction:column;gap:8px}
    .duo-title{font-family:var(--font-display);font-size:20px;font-weight:700;line-height:1.25;letter-spacing:-.02em;transition:color .15s}
    .duo-card:hover .duo-title{color:var(--accent2)}
    .duo-desc{font-size:13px;color:var(--text2);line-height:1.55;flex:1}
    .duo-date{font-family:var(--font-mono);font-size:11px;color:var(--text3);text-transform:uppercase;letter-spacing:.06em}

    /* Stats card */
    .stats-card{background:linear-gradient(135deg,var(--bg2) 0%,rgba(108,99,255,.12) 100%);border:1px solid rgba(108,99,255,.2);padding:40px 32px;display:flex;flex-direction:column;justify-content:center;gap:24px}
    .stats-eyebrow{font-family:var(--font-mono);font-size:11px;text-transform:uppercase;letter-spacing:.1em;color:var(--accent2)}
    .stats-headline{font-family:var(--font-display);font-size:clamp(22px,2.5vw,32px);font-weight:800;line-height:1.2;letter-spacing:-.03em}
    .stats-headline em{font-style:normal;color:var(--accent2)}
    .stats-row{display:flex;gap:32px;flex-wrap:wrap}
    .stat-item{display:flex;flex-direction:column;gap:2px}
    .stat-n{font-family:var(--font-display);font-size:32px;font-weight:800}
    .stat-l{font-size:12px;color:var(--text3)}
    .stats-tags{display:flex;flex-direction:column;gap:8px}
    .stats-tag{font-size:13px;font-weight:600;color:var(--accent2);transition:color .15s}
    .stats-tag:hover{color:var(--text)}

    /* ══════════════════════════════
       SECTION BLOCK
    ══════════════════════════════ */
    .section-block{padding:48px 0}
    .section-head{display:flex;align-items:center;gap:16px;margin-bottom:24px}
    .section-label{font-family:var(--font-display);font-size:13px;font-weight:700;text-transform:uppercase;letter-spacing:.12em;color:var(--text2);white-space:nowrap}
    .section-line{flex:1;height:1px;background:var(--border2)}

    /* ══════════════════════════════
       MAGAZINE GRID
    ══════════════════════════════ */
    .mag-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:2px}
    @media(max-width:900px){.mag-grid{grid-template-columns:repeat(2,1fr)}}
    @media(max-width:600px){.mag-grid{grid-template-columns:1fr}}
    .mag-card{background:var(--bg2);overflow:hidden;display:flex;flex-direction:column;transition:opacity .2s}
    .mag-card:hover{opacity:.88}
    .mag-card-wide{grid-column:span 2}
    @media(max-width:600px){.mag-card-wide{grid-column:span 1}}
    .mag-img{position:relative;height:200px;overflow:hidden}
    .mag-card-wide .mag-img{height:260px}
    .mag-pattern{position:absolute;inset:0;background:radial-gradient(ellipse 100% 100% at calc(30% + var(--i,0)*7%) 50%,hsl(var(--hue),55%,20%) 0%,hsl(var(--hue),30%,8%) 100%)}
    .mag-img-overlay{position:absolute;inset:0;background:linear-gradient(to top,var(--bg2) 0%,transparent 55%)}
    .mag-tag{position:absolute;top:14px;left:14px}
    .mag-body{padding:20px;flex:1;display:flex;flex-direction:column;gap:6px}
    .mag-title{font-family:var(--font-display);font-size:16px;font-weight:700;line-height:1.3;letter-spacing:-.015em;transition:color .15s}
    .mag-card:hover .mag-title{color:var(--accent2)}
    .mag-card-wide .mag-title{font-size:20px}
    .mag-desc{font-size:12px;color:var(--text2);line-height:1.55;flex:1}
    .mag-date{font-family:var(--font-mono);font-size:10px;color:var(--text3);text-transform:uppercase;letter-spacing:.06em;margin-top:4px}

    /* ══════════════════════════════
       ARTICLE PAGE
    ══════════════════════════════ */
    .article-layout{display:grid;grid-template-columns:1fr 260px;gap:56px;padding:56px 0 80px;align-items:start}
    @media(max-width:900px){.article-layout{grid-template-columns:1fr}.article-sidebar{display:none}}
    .article-header{margin-bottom:36px}
    .article-header .meta{display:flex;align-items:center;gap:12px;margin-bottom:16px}
    .article-header .date{font-family:var(--font-mono);font-size:11px;color:var(--text3);text-transform:uppercase;letter-spacing:.06em}
    article h1{font-family:var(--font-display);font-size:clamp(26px,4vw,40px);font-weight:800;line-height:1.15;letter-spacing:-.03em;margin-bottom:16px}
    .article-desc{font-size:17px;color:var(--text2);line-height:1.65;padding-bottom:32px;border-bottom:1px solid var(--border);margin-bottom:32px}
    article h2{font-family:var(--font-display);font-size:22px;font-weight:700;margin:40px 0 14px;letter-spacing:-.02em}
    article h3{font-size:17px;font-weight:600;margin:28px 0 8px;color:var(--text2)}
    article p{margin-bottom:18px;color:var(--text2);line-height:1.75}
    article strong{color:var(--text)}
    article a{color:var(--accent2);border-bottom:1px solid rgba(167,139,250,.3);transition:border-color .15s}
    article a:hover{border-color:var(--accent2)}
    article ul,article ol{padding-left:24px;margin-bottom:18px;color:var(--text2)}
    article li{margin-bottom:8px}
    article blockquote{border-left:3px solid var(--accent);padding:12px 20px;margin:24px 0;background:var(--bg2);border-radius:0 8px 8px 0;color:var(--text2);font-style:italic}
    article code{font-family:var(--font-mono);font-size:13px;background:var(--bg3);color:var(--accent2);padding:2px 7px;border-radius:4px;border:1px solid var(--border2)}
    article pre{background:var(--bg2);border:1px solid var(--border2);border-radius:10px;padding:24px;overflow-x:auto;margin:24px 0}
    article pre code{background:none;border:none;padding:0;color:var(--text)}
    article table{width:100%;border-collapse:collapse;font-size:14px;margin:24px 0}
    article th{background:var(--bg3);border:1px solid var(--border2);padding:10px 14px;text-align:left;font-family:var(--font-mono);font-size:11px;text-transform:uppercase;letter-spacing:.06em;color:var(--text2)}
    article td{border:1px solid var(--border);padding:10px 14px;color:var(--text2)}
    article img{max-width:100%;border-radius:10px;border:1px solid var(--border2)}
    .article-sidebar{position:sticky;top:80px}
    .sidebar-box{background:var(--bg2);border:1px solid var(--border);border-radius:12px;padding:20px}
    .sidebar-box+.sidebar-box{margin-top:16px}
    .sidebar-title{font-family:var(--font-mono);font-size:10px;text-transform:uppercase;letter-spacing:.1em;color:var(--text3);margin-bottom:14px}
    .toc-list{list-style:none}
    .toc-list li a{display:block;padding:5px 0 5px 12px;font-size:13px;color:var(--text2);border-left:2px solid var(--border2);transition:color .15s,border-color .15s;text-decoration:none;border-bottom:none}
    .toc-list li a:hover{color:var(--accent2);border-color:var(--accent2)}

    /* ══════════════════════════════
       CATEGORY PAGE
    ══════════════════════════════ */
    .cat-header{padding:56px 0 40px;border-bottom:1px solid var(--border);margin-bottom:0}
    .cat-header h1{font-family:var(--font-display);font-size:clamp(28px,4vw,44px);font-weight:800;letter-spacing:-.03em;margin:12px 0 12px}
    .cat-header p{font-size:16px;color:var(--text2);max-width:520px}
    .article-list{display:flex;flex-direction:column}
    .list-item{display:flex;align-items:flex-start;gap:20px;padding:24px 0;border-bottom:1px solid var(--border);transition:opacity .15s}
    .list-item:first-child{border-top:1px solid var(--border)}
    .list-item:hover{opacity:.8}
    .list-item-num{font-family:var(--font-mono);font-size:12px;color:var(--text3);min-width:28px;padding-top:3px}
    .list-item-body{flex:1}
    .list-item-title{font-family:var(--font-display);font-size:18px;font-weight:700;letter-spacing:-.015em;color:var(--text);transition:color .15s;margin-bottom:4px}
    .list-item:hover .list-item-title{color:var(--accent2)}
    .list-item-desc{font-size:14px;color:var(--text2);line-height:1.55;margin-bottom:8px}
    .list-item-date{font-family:var(--font-mono);font-size:11px;color:var(--text3)}
    .list-item-arrow{font-size:18px;color:var(--text3);transition:color .15s,transform .15s;align-self:center}
    .list-item:hover .list-item-arrow{color:var(--accent2);transform:translateX(3px)}

    /* ── FOOTER ── */
    .site-footer{border-top:1px solid var(--border);padding:40px 0;margin-top:0}
    .footer-inner{max-width:1200px;margin:0 auto;padding:0 32px;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:16px}
    .footer-brand{font-family:var(--font-display);font-weight:700;font-size:15px}
    .footer-brand span{color:var(--accent2)}
    .footer-desc{font-size:12px;color:var(--text3);margin-top:3px}
    .footer-links{display:flex;gap:20px}
    .footer-links a{font-size:13px;color:var(--text3);transition:color .15s}
    .footer-links a:hover{color:var(--accent2)}
  </style>
</head>
<body>
<header class="site-header">
  <div class="header-inner">
    <a href="/" class="logo">
      <div class="logo-icon">Ø</div>
      Zero Click<span class="logo-dot"> Journal</span>
    </a>
    <nav>
      <a href="/seo">SEO</a>
      <a href="/ai">AI</a>
      <a href="/llm">LLM</a>
      <a href="/seo" class="nav-cta">Read Now →</a>
    </nav>
  </div>
</header>
<slot />
<footer class="site-footer">
  <div class="footer-inner">
    <div>
      <div class="footer-brand">Zero Click<span> Journal</span></div>
      <div class="footer-desc">Structured knowledge for AI crawlers &amp; B2B researchers</div>
    </div>
    <div class="footer-links">
      <a href="/seo">SEO</a>
      <a href="/ai">AI</a>
      <a href="/llm">LLM</a>
      <a href="/robots.txt">robots.txt</a>
    </div>
    <span style="font-size:12px;color:var(--text3)">© {new Date().getFullYear()} Zero Click Journal</span>
  </div>
</footer>
</body>
</html>
