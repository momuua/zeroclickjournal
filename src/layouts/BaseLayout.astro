---
export interface Props {
  title: string;
  description: string;
  pubDate?: Date;
  modDate?: Date;
  isFAQ?: boolean;
  faqItems?: { question: string; answer: string }[];
}
const { title, description, pubDate, modDate, isFAQ = false, faqItems = [] } = Astro.props;
const siteUrl = 'https://zeroclickjournal.com';
const canonicalURL = new URL(Astro.url.pathname, siteUrl);
const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": title,
  "description": description,
  "url": canonicalURL.toString(),
  "publisher": { "@type": "Organization", "name": "Zero Click Journal", "url": siteUrl },
  ...(pubDate && { "datePublished": pubDate.toISOString() }),
  ...(modDate && { "dateModified": modDate.toISOString() }),
};
const faqSchema = isFAQ && faqItems.length > 0 ? {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqItems.map(item => ({
    "@type": "Question",
    "name": item.question,
    "acceptedAnswer": { "@type": "Answer", "text": item.answer }
  }))
} : null;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />
  <title>{title} — Zero Click Journal</title>
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:type" content="article" />
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  {faqSchema && <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />}
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <style>
    :root {
      --white:#fff;--gray50:#f9fafb;--gray100:#f3f4f6;--gray200:#e5e7eb;
      --gray400:#9ca3af;--gray600:#6b7280;--gray800:#1f2937;--gray900:#111827;
      --text:#333333;--text2:#6b7280;--text3:#9ca3af;
      --blue:#1d4ed8;--blue-light:#dbeafe;--blue-dark:#1e3a8a;
      --teal:#0d9488;--teal-light:#ccfbf1;--teal-dark:#134e4a;
      --font:'Inter',system-ui,sans-serif;
      --font-mono:'JetBrains Mono',monospace;
    }
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    html{font-family:var(--font);background:var(--white);color:var(--text);font-size:16px;line-height:1.7;-webkit-font-smoothing:antialiased}
    a{color:inherit;text-decoration:none}
    img{max-width:100%;display:block}
    .wrap{max-width:1100px;margin:0 auto;padding:0 20px}

    /* ── HEADER ── */
    .site-header{position:sticky;top:0;z-index:100;background:rgba(255,255,255,.95);backdrop-filter:blur(8px);border-bottom:1px solid var(--gray200)}
    .hdr-inner{max-width:1100px;margin:0 auto;padding:0 20px;display:flex;align-items:center;justify-content:space-between;height:54px;gap:16px}
    .logo{display:flex;align-items:center;gap:8px;font-weight:700;font-size:16px;letter-spacing:-.02em;color:#111;flex-shrink:0}
    .logo-icon{width:28px;height:28px;background:var(--blue);border-radius:6px;display:flex;align-items:center;justify-content:center;color:#fff;font-size:13px;font-weight:800;font-family:var(--font-mono)}
    .logo span{color:var(--teal)}
    .main-nav{display:flex;align-items:center;gap:2px;flex:1;justify-content:center}
    .main-nav a{font-size:13px;font-weight:500;color:var(--text2);padding:5px 10px;border-radius:4px;transition:color .15s,background .15s;white-space:nowrap}
    .main-nav a:hover{color:var(--blue);background:var(--blue-light)}
    .search-btn{width:34px;height:34px;border:1px solid var(--gray200);border-radius:6px;background:var(--white);display:flex;align-items:center;justify-content:center;cursor:pointer;color:var(--text2);flex-shrink:0;transition:border-color .15s}
    .search-btn:hover{border-color:var(--blue);color:var(--blue)}
    @media(max-width:768px){.main-nav{display:none}}

    /* ── TAGS ── */
    .tag{display:inline-block;font-size:9px;font-weight:700;padding:3px 7px;border-radius:3px;text-transform:uppercase;letter-spacing:.06em;line-height:1}
    .tag-tech{background:var(--blue);color:#fff}
    .tag-health{background:var(--teal);color:#fff}
    .tag-llm{background:#7c3aed;color:#fff}
    .tag-drug{background:#0e7490;color:#fff}
    .tag-deep{background:#374151;color:#fff}

    /* ── HERO ── */
    .hero-main{position:relative;height:420px;overflow:hidden;background:linear-gradient(135deg,#0f172a 0%,#1e3a5f 55%,#0c4a6e 100%)}
    .hero-overlay{position:absolute;inset:0;background:linear-gradient(to top,rgba(0,0,0,.8) 0%,rgba(0,0,0,.25) 55%,transparent 100%)}
    .hero-content{position:absolute;bottom:0;left:0;right:0;padding:36px 20px}
    .hero-inner{max-width:1100px;margin:0 auto}
    .hero-title{font-size:clamp(22px,3.5vw,34px);font-weight:700;color:#fff;line-height:1.2;letter-spacing:-.025em;max-width:700px;margin:10px 0 10px;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden}
    .hero-desc{font-size:14px;color:rgba(255,255,255,.65);max-width:580px;margin-bottom:12px;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden}
    .hero-meta{font-size:10px;color:rgba(255,255,255,.45);text-transform:uppercase;letter-spacing:.08em;font-family:var(--font-mono)}

    /* ── HERO DUO ── */
    .hero-duo{display:grid;grid-template-columns:1fr 1fr;gap:2px;margin-bottom:2px}
    @media(max-width:640px){.hero-duo{grid-template-columns:1fr}}
    .hero-s{position:relative;height:210px;overflow:hidden;cursor:pointer}
    .hero-s.c-blue{background:linear-gradient(135deg,#1e3a8a,#2563eb)}
    .hero-s.c-teal{background:linear-gradient(135deg,#134e4a,#0f9488)}
    .hero-s-overlay{position:absolute;inset:0;background:linear-gradient(to top,rgba(0,0,0,.72) 0%,transparent 65%)}
    .hero-s-body{position:absolute;bottom:0;left:0;right:0;padding:18px}
    .hero-s-title{font-size:14px;font-weight:700;color:#fff;line-height:1.35;margin:6px 0 6px;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden}
    .hero-s-date{font-size:10px;color:rgba(255,255,255,.45);text-transform:uppercase;letter-spacing:.07em;font-family:var(--font-mono)}

    /* ── SECTION HEAD ── */
    .section{padding:36px 0}
    .section-head{display:flex;align-items:center;gap:12px;margin-bottom:20px}
    .section-label{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.12em;color:var(--text3);white-space:nowrap}
    .section-line{flex:1;height:1px;background:var(--gray200)}
    .section-more{font-size:11px;color:var(--blue);white-space:nowrap;font-weight:600}
    .section-more:hover{color:var(--blue-dark)}

    /* ── CARD GRID ── */
    .card-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:18px}
    @media(max-width:900px){.card-grid{grid-template-columns:repeat(2,1fr)}}
    @media(max-width:480px){.card-grid{grid-template-columns:1fr}}
    .card{display:flex;flex-direction:column;cursor:pointer}
    .card:hover .card-title{color:var(--blue)}
    .card-thumb{height:140px;border-radius:6px;overflow:hidden;margin-bottom:10px;position:relative;background:var(--gray100)}
    .card-thumb.bg-tech{background:linear-gradient(135deg,#1e3a8a,#2563eb)}
    .card-thumb.bg-health{background:linear-gradient(135deg,#134e4a,#14b8a6)}
    .card-thumb.bg-llm{background:linear-gradient(135deg,#4c1d95,#7c3aed)}
    .card-thumb.bg-drug{background:linear-gradient(135deg,#0c4a6e,#0891b2)}
    .card-thumb-tag{position:absolute;top:8px;left:8px}
    .card-title{font-size:13px;font-weight:700;color:var(--text);line-height:1.4;margin-bottom:6px;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;transition:color .15s}
    .card-date{font-size:10px;color:var(--text3);text-transform:uppercase;letter-spacing:.06em;font-family:var(--font-mono)}

    /* ── DEEP FEATURES ── */
    .deep-section{background:var(--gray50);border-radius:8px;padding:24px;margin-bottom:8px}
    .feat-list{display:flex;flex-direction:column;gap:12px}
    .feat-item{display:flex;gap:16px;padding:18px;background:var(--white);border-radius:6px;border:1px solid var(--gray200);cursor:pointer;transition:border-color .15s}
    .feat-item:hover{border-color:var(--blue-light)}
    .feat-num{font-size:11px;font-weight:700;color:var(--text3);min-width:24px;padding-top:2px;font-family:var(--font-mono)}
    .feat-body{flex:1;min-width:0}
    .feat-title{font-size:15px;font-weight:700;color:var(--text);margin:6px 0 6px;line-height:1.35;transition:color .15s}
    .feat-item:hover .feat-title{color:var(--blue)}
    .feat-desc{font-size:13px;color:var(--text2);line-height:1.55}
    .feat-date{font-size:10px;color:var(--text3);text-transform:uppercase;letter-spacing:.07em;margin-top:8px;font-family:var(--font-mono)}

    /* ── FOOTER ── */
    .site-footer{background:var(--gray900);color:#9ca3af;padding:44px 20px 24px;margin-top:48px}
    .ftr-inner{max-width:1100px;margin:0 auto}
    .ftr-grid{display:grid;grid-template-columns:2fr 1fr 1fr 1fr;gap:32px;margin-bottom:32px}
    @media(max-width:768px){.ftr-grid{grid-template-columns:1fr 1fr}}
    @media(max-width:480px){.ftr-grid{grid-template-columns:1fr}}
    .ftr-brand{display:flex;align-items:center;gap:8px;font-size:15px;font-weight:700;color:#fff;margin-bottom:10px}
    .ftr-brand-icon{width:26px;height:26px;background:var(--blue);border-radius:5px;display:flex;align-items:center;justify-content:center;color:#fff;font-size:12px;font-weight:800;font-family:var(--font-mono)}
    .ftr-brand span{color:var(--teal)}
    .ftr-desc{font-size:12px;line-height:1.65;color:#6b7280}
    .ftr-col-title{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.1em;color:#d1d5db;margin-bottom:12px}
    .ftr-links{display:flex;flex-direction:column;gap:7px}
    .ftr-links a{font-size:12px;color:#6b7280;transition:color .15s}
    .ftr-links a:hover{color:#fff}
    .ftr-bottom{border-top:1px solid #1f2937;padding-top:20px;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:10px}
    .ftr-copy{font-size:11px;color:#4b5563}
    .ftr-legal{display:flex;gap:16px}
    .ftr-legal a{font-size:11px;color:#4b5563;transition:color .15s}
    .ftr-legal a:hover{color:#9ca3af}

    /* ── ARTICLE PAGE ── */
    .article-wrap{display:grid;grid-template-columns:1fr 260px;gap:48px;padding:48px 0 80px;align-items:start}
    @media(max-width:900px){.article-wrap{grid-template-columns:1fr}.article-sidebar{display:none}}
    .article-header{margin-bottom:28px}
    .article-meta{display:flex;align-items:center;gap:10px;margin-bottom:14px}
    .article-date{font-size:11px;color:var(--text3);text-transform:uppercase;letter-spacing:.07em;font-family:var(--font-mono)}
    article h1{font-size:clamp(24px,4vw,36px);font-weight:700;line-height:1.2;letter-spacing:-.025em;color:#111;margin-bottom:14px}
    .article-desc{font-size:16px;color:var(--text2);line-height:1.65;padding-bottom:28px;border-bottom:1px solid var(--gray200);margin-bottom:28px}
    article h2{font-size:21px;font-weight:700;color:#111;margin:36px 0 12px;letter-spacing:-.015em}
    article h3{font-size:17px;font-weight:600;color:#333;margin:26px 0 8px}
    article p{font-size:15px;color:var(--text2);line-height:1.75;margin-bottom:16px}
    article strong{color:#111}
    article a{color:var(--blue);border-bottom:1px solid var(--blue-light)}
    article a:hover{border-color:var(--blue)}
    article ul,article ol{padding-left:22px;margin-bottom:16px;color:var(--text2)}
    article li{margin-bottom:7px;font-size:15px}
    article blockquote{border-left:3px solid var(--blue);padding:10px 18px;margin:22px 0;background:var(--gray50);color:var(--text2);font-style:italic;border-radius:0 6px 6px 0}
    article code{font-family:var(--font-mono);font-size:13px;background:var(--gray100);color:#b91c1c;padding:2px 6px;border-radius:4px;border:1px solid var(--gray200)}
    article pre{background:var(--gray900);border-radius:8px;padding:22px;overflow-x:auto;margin:22px 0}
    article pre code{background:none;border:none;padding:0;color:#e5e7eb}
    article table{width:100%;border-collapse:collapse;font-size:14px;margin:22px 0}
    article th{background:var(--gray50);border:1px solid var(--gray200);padding:10px 12px;text-align:left;font-size:11px;font-family:var(--font-mono);text-transform:uppercase;letter-spacing:.05em;color:var(--text2)}
    article td{border:1px solid var(--gray200);padding:10px 12px;color:var(--text2)}
    article img{border-radius:8px;border:1px solid var(--gray200)}
    .article-sidebar{position:sticky;top:72px}
    .sidebar-box{background:var(--gray50);border:1px solid var(--gray200);border-radius:8px;padding:18px}
    .sidebar-box+.sidebar-box{margin-top:14px}
    .sidebar-title{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.1em;color:var(--text3);margin-bottom:12px;font-family:var(--font-mono)}
    .toc-list{list-style:none}
    .toc-list li a{display:block;padding:4px 0 4px 12px;font-size:13px;color:var(--text2);border-left:2px solid var(--gray200);transition:color .15s,border-color .15s;text-decoration:none}
    .toc-list li a:hover{color:var(--blue);border-color:var(--blue)}

    /* ── CATEGORY PAGE ── */
    .cat-header{padding:48px 0 36px;border-bottom:1px solid var(--gray200);margin-bottom:0}
    .cat-header h1{font-size:clamp(26px,4vw,40px);font-weight:700;letter-spacing:-.025em;color:#111;margin:10px 0 10px}
    .cat-header p{font-size:15px;color:var(--text2);max-width:500px}
    .article-list{display:flex;flex-direction:column}
    .list-item{display:flex;align-items:flex-start;gap:18px;padding:22px 0;border-bottom:1px solid var(--gray200);cursor:pointer;transition:opacity .15s}
    .list-item:first-child{border-top:1px solid var(--gray200)}
    .list-item:hover{opacity:.75}
    .list-num{font-size:11px;font-weight:700;color:var(--text3);min-width:26px;padding-top:3px;font-family:var(--font-mono)}
    .list-body{flex:1}
    .list-title{font-size:17px;font-weight:700;color:#111;margin-bottom:4px;transition:color .15s;letter-spacing:-.01em}
    .list-item:hover .list-title{color:var(--blue)}
    .list-desc{font-size:13px;color:var(--text2);line-height:1.55;margin-bottom:7px}
    .list-date{font-size:10px;color:var(--text3);text-transform:uppercase;letter-spacing:.07em;font-family:var(--font-mono)}
    .list-arrow{font-size:18px;color:var(--text3);align-self:center;transition:color .15s,transform .15s}
    .list-item:hover .list-arrow{color:var(--blue);transform:translateX(3px)}
  </style>
</head>
<body>
<header class="site-header">
  <div class="hdr-inner">
    <a href="/" class="logo">
      <div class="logo-icon">Ø</div>
      Zero Click<span>Journal</span>
    </a>
    <nav class="main-nav">
      <a href="/ai">AI & LLM</a>
      <a href="/llm">Smart Hardware</a>
      <a href="/seo">Digital Health</a>
      <a href="/seo">Drug Research</a>
      <a href="/seo">Deep Dives</a>
    </nav>
    <button class="search-btn" aria-label="Search">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
    </button>
  </div>
</header>
<slot />
<footer class="site-footer">
  <div class="ftr-inner">
    <div class="ftr-grid">
      <div>
        <div class="ftr-brand">
          <div class="ftr-brand-icon">Ø</div>
          Zero Click<span>Journal</span>
        </div>
        <p class="ftr-desc">High-density structured knowledge at the intersection of AI and healthcare. Built for researchers, analysts, and AI crawlers. No ads. No paywalls.</p>
      </div>
      <div>
        <div class="ftr-col-title">Categories</div>
        <div class="ftr-links">
          <a href="/ai">AI & LLM</a>
          <a href="/llm">Smart Hardware</a>
          <a href="/seo">Digital Health</a>
          <a href="/seo">Drug Research</a>
          <a href="/seo">Deep Dives</a>
        </div>
      </div>
      <div>
        <div class="ftr-col-title">About</div>
        <div class="ftr-links">
          <a href="#">About Us</a>
          <a href="#">Editorial Policy</a>
          <a href="#">Contact</a>
          <a href="/robots.txt">robots.txt</a>
          <a href="/sitemap-index.xml">Sitemap</a>
        </div>
      </div>
      <div>
        <div class="ftr-col-title">Legal</div>
        <div class="ftr-links">
          <a href="#">Disclaimer</a>
          <a href="#">Privacy Policy</a>
          <a href="#">Cookie Policy</a>
          <a href="#">Terms of Use</a>
        </div>
      </div>
    </div>
    <div class="ftr-bottom">
      <span class="ftr-copy">© {new Date().getFullYear()} Zero Click Journal · zeroclickjournal.com</span>
      <div class="ftr-legal">
        <a href="#">Privacy</a>
        <a href="#">Terms</a>
        <a href="#">Cookies</a>
      </div>
    </div>
  </div>
</footer>
</body>
</html>
