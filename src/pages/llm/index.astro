---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
const articles = (await getCollection('articles', ({data}) => data.category === 'llm'))
  .sort((a,b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
---
<BaseLayout title="LLM Technology - Zero Click Journal" description="Language model training, inference, and deployment.">
  <div class="wrap">
    <div class="cat-header">
      <span class="tag tag-llm">LLM Technology</span>
      <h1>LLM Technology</h1>
      <p>Precise documentation on language model training, inference, and deployment strategies.</p>
    </div>
    <div class="article-list">
      {articles.map((e, i) => (
        <a href={`/llm/${e.slug.split('/').pop()}`} class="list-item">
          <span class="list-num">{String(i+1).padStart(2,'0')}</span>
          <div class="list-body">
            <div class="list-title">{e.data.title}</div>
            <div class="list-desc">{e.data.description}</div>
            <div class="list-date">{e.data.pubDate.toISOString().slice(0,10)}</div>
          </div>
          <span class="list-arrow">→</span>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>
