---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
const articles = (await getCollection('articles', ({data}) => data.category === 'llm'))
  .sort((a,b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
---
<BaseLayout title="LLM Technology — Zero Click Journal" description="Technical documentation on large language models, training methods, and inference optimization.">
  <div class="wrap">
    <div class="cat-header">
      <span class="tag tag-llm">LLM</span>
      <h1>Large Language<br />Model Technology</h1>
      <p>Precise technical documentation on LLM architecture, training methodology, and deployment strategies.</p>
    </div>
    <div class="article-list">
      {articles.map((e, i) => (
        <a href={`/llm/${e.slug.split('/').pop()}`} class="list-item">
          <span class="list-item-num">0{i+1}</span>
          <div class="list-item-body">
            <p class="list-item-title">{e.data.title}</p>
            <p class="list-item-desc">{e.data.description}</p>
            <div class="list-item-meta">
              <span class="list-item-date">{e.data.pubDate.toISOString().slice(0,10)}</span>
            </div>
          </div>
          <span class="list-item-arrow">→</span>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>
