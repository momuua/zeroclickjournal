---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
const articles = (await getCollection('articles', ({data}) => data.category === 'seo'))
  .sort((a,b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
const tagClass = '{'seo':'tag-health','ai':'tag-tech','llm':'tag-llm'}['seo'] ?? 'tag-deep'';
---
<BaseLayout title="Digital Health — Zero Click Journal" description="In-depth coverage of AI-powered diagnostics, digital therapeutics, and healthcare technology.">
  <div class="wrap">
    <div class="cat-header">
      <span class="tag tag-health">Digital Health</span>
      <h1>Digital Health</h1>
      <p>In-depth coverage of AI-powered diagnostics, digital therapeutics, and healthcare technology.</p>
    </div>
    <div class="article-list">
      {articles.map((e, i) => (
        <a href={`/seo/{e.slug.split('/').pop()}`} class="list-item">
          <span class="list-num">{String(i+1).padStart(2,'0')}</span>
          <div class="list-body">
            <div class="list-title">{e.data.title}</div>
            <div class="list-desc">{e.data.description}</div>
            <div class="list-date">{e.data.pubDate.toISOString().slice(0,10)}</div>
          </div>
          <span class="list-arrow">→</span>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>
