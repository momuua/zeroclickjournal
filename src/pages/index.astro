---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const all = await getCollection('articles');
const sorted = all.sort((a,b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
const hero = sorted[0];
const featured2 = sorted[1];
const grid = sorted.slice(2);

const slugFor = (e: typeof hero) => `/${e.data.category}/${e.slug.split('/').pop()}`;
const tagClass = (c: string) => ({ seo:'tag-seo', ai:'tag-ai', llm:'tag-llm' }[c] ?? '');
const tagLabel = (c: string) => ({ seo:'SEO & GEO', ai:'AI Systems', llm:'LLM' }[c] ?? c.toUpperCase());
---
<BaseLayout title="Zero Click Journal — AI Knowledge Base" description="High-density structured articles on SEO, AI systems, and LLM technology. Written for AI crawlers and B2B researchers.">

  <!-- ═══ HERO BANNER ═══ -->
  <div class="hero-banner">
    <a href={slugFor(hero)} class="hero-link">
      <div class="hero-img-wrap">
        <div class="hero-img-placeholder">
          <div class="hero-pattern"></div>
          <div class="hero-gradient"></div>
        </div>
        <div class="hero-overlay">
          <div class="wrap">
            <span class={`tag ${tagClass(hero.data.category)}`}>{tagLabel(hero.data.category)}</span>
            <h1 class="hero-title">{hero.data.title}</h1>
            <p class="hero-desc">{hero.data.description}</p>
            <span class="hero-date">{hero.data.pubDate.toISOString().slice(0,10)}</span>
          </div>
        </div>
      </div>
    </a>
  </div>

  <!-- ═══ TOP 2 FEATURED ═══ -->
  <div class="wrap">
    <div class="duo-grid">
      {featured2 && (
        <a href={slugFor(featured2)} class="duo-card">
          <div class="duo-img">
            <div class="duo-pattern" style={`--hue:${featured2.data.category==='seo'?'160':featured2.data.category==='ai'?'250':'30'}`}></div>
            <div class="duo-img-overlay"></div>
          </div>
          <div class="duo-body">
            <span class={`tag ${tagClass(featured2.data.category)}`}>{tagLabel(featured2.data.category)}</span>
            <h2 class="duo-title">{featured2.data.title}</h2>
            <p class="duo-desc">{featured2.data.description}</p>
            <span class="duo-date">{featured2.data.pubDate.toISOString().slice(0,10)}</span>
          </div>
        </a>
      )}
      <!-- Stats card -->
      <div class="stats-card">
        <div class="stats-eyebrow">Zero Click Journal</div>
        <p class="stats-headline">The journal that answers<br/><em>before you click</em></p>
        <div class="stats-row">
          <div class="stat-item"><span class="stat-n">{all.length}</span><span class="stat-l">Articles</span></div>
          <div class="stat-item"><span class="stat-n">3</span><span class="stat-l">Categories</span></div>
          <div class="stat-item"><span class="stat-n">100%</span><span class="stat-l">Open crawlers</span></div>
        </div>
        <div class="stats-tags">
          <a href="/seo" class="stats-tag">SEO & GEO →</a>
          <a href="/ai" class="stats-tag">AI Systems →</a>
          <a href="/llm" class="stats-tag">LLM →</a>
        </div>
      </div>
    </div>
  </div>

  <!-- ═══ SECTION: LATEST ═══ -->
  <div class="wrap">
    <div class="section-block">
      <div class="section-head">
        <h2 class="section-label">Latest Articles</h2>
        <div class="section-line"></div>
      </div>
      <div class="mag-grid">
        {grid.map((e, i) => (
          <a href={slugFor(e)} class={`mag-card ${i===0?'mag-card-wide':''}`}>
            <div class="mag-img">
              <div class="mag-pattern" style={`--hue:${e.data.category==='seo'?'160':e.data.category==='ai'?'250':'30'};--i:${i}`}></div>
              <div class="mag-img-overlay"></div>
              <span class={`mag-tag tag ${tagClass(e.data.category)}`}>{tagLabel(e.data.category)}</span>
            </div>
            <div class="mag-body">
              <h3 class="mag-title">{e.data.title}</h3>
              <p class="mag-desc">{e.data.description}</p>
              <span class="mag-date">{e.data.pubDate.toISOString().slice(0,10)}</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </div>

</BaseLayout>
