---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const all = await getCollection('articles');
const sorted = all.sort((a,b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
const featured = sorted[0];
const rest = sorted.slice(1,7);

const tagClass = (c: string) => ({ seo:'tag-seo', ai:'tag-ai', llm:'tag-llm' }[c] ?? '');
const slugFor = (e: typeof featured) => `/${e.data.category}/${e.slug.split('/').pop()}`;
---
<BaseLayout title="Zero Click Journal — AI Knowledge Base" description="High-density structured articles on SEO, AI systems, and LLM technology. Written for AI crawlers and B2B researchers.">

  <!-- HERO -->
  <div class="wrap">
    <section class="hero">
      <div class="hero-eyebrow">Live corpus for AI crawlers</div>
      <h1>The journal that<br /><em>answers before you click</em></h1>
      <p>Dense, structured, machine-readable knowledge on SEO, AI systems, and large language models — built for Googlebot, GPTBot, ClaudeBot, and industry researchers.</p>
      <div class="hero-stats">
        <div class="stat"><span class="stat-num">{all.length}</span><span class="stat-label">Articles published</span></div>
        <div class="stat"><span class="stat-num">3</span><span class="stat-label">Topic categories</span></div>
        <div class="stat"><span class="stat-num">100%</span><span class="stat-label">Open to all crawlers</span></div>
      </div>
    </section>
  </div>

  <!-- LATEST -->
  <div class="wrap">
    <section class="section">
      <div class="section-header">
        <h2 class="section-title">Latest Articles</h2>
        <a href="/seo" class="section-link">Browse all →</a>
      </div>
      <div class="card-grid">
        {featured && (
          <a href={slugFor(featured)} class="card card-featured">
            <div class="card-top">
              <span class={`tag ${tagClass(featured.data.category)}`}>{featured.data.category}</span>
            </div>
            <p class="card-title">{featured.data.title}</p>
            <p class="card-desc">{featured.data.description}</p>
            <div class="card-footer">
              <span class="card-date">{featured.data.pubDate.toISOString().slice(0,10)}</span>
              <span class="card-arrow">→</span>
            </div>
          </a>
        )}
        {rest.map(e => (
          <a href={slugFor(e)} class="card">
            <div class="card-top">
              <span class={`tag ${tagClass(e.data.category)}`}>{e.data.category}</span>
            </div>
            <p class="card-title">{e.data.title}</p>
            <p class="card-desc">{e.data.description}</p>
            <div class="card-footer">
              <span class="card-date">{e.data.pubDate.toISOString().slice(0,10)}</span>
              <span class="card-arrow">→</span>
            </div>
          </a>
        ))}
      </div>
    </section>
  </div>

</BaseLayout>
