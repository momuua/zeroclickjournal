---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
const articles = (await getCollection('articles', ({data}) => data.category === 'ai'))
  .sort((a,b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
---
<BaseLayout title="AI Systems — Zero Click Journal" description="In-depth technical articles on AI systems, machine learning, and enterprise AI adoption.">
  <div class="wrap">
    <div class="cat-header">
      <span class="tag tag-ai">AI</span>
      <h1>AI Systems</h1>
      <p>Technical breakdowns of AI architectures, enterprise deployment patterns, and emerging AI capabilities.</p>
    </div>
    <div class="article-list">
      {articles.map((e, i) => (
        <a href={`/ai/${e.slug.split('/').pop()}`} class="list-item">
          <span class="list-item-num">0{i+1}</span>
          <div class="list-item-body">
            <p class="list-item-title">{e.data.title}</p>
            <p class="list-item-desc">{e.data.description}</p>
            <div class="list-item-meta">
              <span class="list-item-date">{e.data.pubDate.toISOString().slice(0,10)}</span>
            </div>
          </div>
          <span class="list-item-arrow">→</span>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>
