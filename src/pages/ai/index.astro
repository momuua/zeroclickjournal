---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
const articles = (await getCollection('articles', ({data}) => data.category === 'ai'))
  .sort((a,b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
const tagClass = '{'seo':'tag-health','ai':'tag-tech','llm':'tag-llm'}['ai'] ?? 'tag-deep'';
---
<BaseLayout title="AI & LLM — Zero Click Journal" description="Technical analysis of large language models, AI architectures, and enterprise AI adoption.">
  <div class="wrap">
    <div class="cat-header">
      <span class="tag tag-tech">AI & LLM</span>
      <h1>AI & LLM</h1>
      <p>Technical analysis of large language models, AI architectures, and enterprise AI adoption.</p>
    </div>
    <div class="article-list">
      {articles.map((e, i) => (
        <a href={`/ai/{e.slug.split('/').pop()}`} class="list-item">
          <span class="list-num">{String(i+1).padStart(2,'0')}</span>
          <div class="list-body">
            <div class="list-title">{e.data.title}</div>
            <div class="list-desc">{e.data.description}</div>
            <div class="list-date">{e.data.pubDate.toISOString().slice(0,10)}</div>
          </div>
          <span class="list-arrow">→</span>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>
